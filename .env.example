# Per-site basic auth for write operations (PUT/DELETE under /recipes/*)
MAIN_BASIC_AUTH_USER=admin
MAIN_BASIC_AUTH_PASS=change-me-main

# Optional secret for signing writer login cookies. If omitted, a derived secret is used.
WRITER_SESSION_SECRET=change-me-session-secret

# Optional SQLite database path for writer users.
# Defaults inside each container to: /app/wiki/.tiddlyharbor/auth.sqlite3
AUTH_DB_PATH=/app/wiki/.tiddlyharbor/auth.sqlite3

SANDBOX_BASIC_AUTH_USER=admin
SANDBOX_BASIC_AUTH_PASS=change-me-sandbox

# Optional git identity used by auto-save commits
GIT_AUTHOR_NAME=TiddlyHarbor Bot
GIT_AUTHOR_EMAIL=tiddlyharbor@example.local

# ── OAuth (optional) ─────────────────────────────────────────────────────
# External base URL for OAuth callbacks (e.g. https://wiki.example.com).
# If empty, OAuth is disabled and only password login is available.
OAUTH_EXTERNAL_BASE_URL=

# GitHub OAuth App credentials.
# Create at: https://github.com/settings/developers → "New OAuth App"
# Set callback URL to: ${OAUTH_EXTERNAL_BASE_URL}/<wiki-name>/auth/github/callback
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Google OAuth credentials.
# Create at: https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: ${OAUTH_EXTERNAL_BASE_URL}/<wiki-name>/auth/google/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# ── Email notifications (optional) ──────────────────────────────────────
# SMTP settings for admin notifications (e.g. new pending users).
# If omitted, notifications are logged to console only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
