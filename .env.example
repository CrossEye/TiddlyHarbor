# Per-site basic auth for write operations (PUT/DELETE under /recipes/*)
MAIN_BASIC_AUTH_USER=admin
MAIN_BASIC_AUTH_PASS=change-me-main

# Optional secret for signing writer login cookies. If omitted, a derived secret is used.
WRITER_SESSION_SECRET=change-me-session-secret

SANDBOX_BASIC_AUTH_USER=admin
SANDBOX_BASIC_AUTH_PASS=change-me-sandbox

# Optional git identity used by auto-save commits
GIT_AUTHOR_NAME=TiddlyHarbor Bot
GIT_AUTHOR_EMAIL=tiddlyharbor@example.local
